{
	"name": "@atlaskit/teams-client",
	"version": "4.33.5",
	"description": "A client to retrieve team related data",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "People and Teams Collective"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-monorepo",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"typesVersions": {
		">=4.5 <4.9": {
			"*": [
				"dist/types-ts4.5/*",
				"dist/types-ts4.5/index.d.ts"
			]
		}
	},
	"sideEffects": false,
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./agg-client/types": "./src/services/agg-client/types.ts",
		"./agg-client": "./src/services/agg-client/index.ts",
		"./ari": "./src/common/utils/ari.ts",
		"./association": "./src/types/association.ts",
		"./client": "./src/services/index.ts",
		"./config": "./src/types/config.ts",
		"./endpoints": "./src/mocks/endpoints.ts",
		"./error": "./src/common/utils/error/index.ts",
		"./generate-data": "./src/mocks/generate-data.ts",
		"./has-permission": "./src/common/utils/permissions/has-permission.ts",
		"./initialise-sentry": "./src/services/sentry/utils/initialise-sentry.ts",
		"./legion-client": "./src/services/legion-client/index.ts",
		"./links": "./src/types/links.ts",
		"./main": "./src/services/main.ts",
		"./media": "./src/types/media.ts",
		"./membership": "./src/types/membership.ts",
		"./mocks": "./src/mocks/index.ts",
		"./permissions/types": "./src/common/utils/permissions/types.ts",
		"./permissions": "./src/common/utils/permissions/index.ts",
		"./public": "./src/services/public-api-client/index.ts",
		"./reporting-lines-client/utils/types": "./src/services/reporting-lines-client/utils/types.ts",
		"./sentry/main": "./src/services/sentry/main.ts",
		"./sentry/types": "./src/services/sentry/types.ts",
		"./sentry": "./src/services/sentry/index.ts",
		"./slack": "./src/types/slack.ts",
		"./sort-teams": "./src/common/utils/sort-teams.ts",
		"./team": "./src/common/utils/team.ts",
		"./team-container": "./src/types/team-container.ts",
		"./tenure": "./src/types/tenure.ts",
		"./types/team": "./src/types/team.ts",
		"./types": "./src/types/index.ts",
		"./ufo": "./src/common/utils/ufo/index.ts",
		"./unlink-container-mutation": "./src/services/agg-client/utils/mutations/unlink-container-mutation.ts",
		"./use-query-light/main": "./src/services/use-query-light/main.ts",
		"./use-query-light/types": "./src/services/use-query-light/types.ts",
		"./use-query-light": "./src/services/use-query-light/index.ts",
		"./use-teams-client-setup": "./src/services/hooks/use-teams-client-setup.ts",
		"./use-teams-sentry-client-setup": "./src/services/sentry/utils/use-teams-sentry-client-setup.ts",
		"./user": "./src/types/user.ts",
		"./user-info-provider/main": "./src/services/user-info-provider/main.ts",
		"./user-info-provider": "./src/services/user-info-provider/index.ts",
		"./utils": "./src/common/utils/index.ts"
	},
	"scripts": {
		"generate:types:public-api": "yarn swagger-typescript-api -p ./src/services/public-api-client/swagger.json -o ./src/services/public-api-client/generated/ --modular --no-client --union-enums",
		"generate:docs:teams-client": "ts-node --project ../../../tsconfig.node.json ./scripts/generate-docs.ts && yarn ../../.. prettier --write packages/people-and-teams/teams-client/docs",
		"test:coverage": "(cd ../../.. && yarn test 'packages/people-and-teams/teams-client/src' --coverage --coverageProvider=v8 --collectCoverageFrom='[\"packages/people-and-teams/teams-client/src/**\", \"!packages/people-and-teams/teams-client/src/**/**/types.ts\", \"!packages/people-and-teams/teams-client/src/ui/**/styled.tsx\"]')"
	},
	"dependencies": {
		"@atlaskit/atlassian-context": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/ufo": "workspace:^",
		"@babel/runtime": "root:*",
		"@sentry/browser": "root:*",
		"date-fns-tz": "root:*",
		"faker": "root:*",
		"graphql": "root:*",
		"graphql-tag": "root:*",
		"lodash": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@atlaskit/feature-gate-js-client": "workspace:^",
		"@atlassian/codegen": "workspace:^",
		"@atlassian/ptc-test-utils": "workspace:^",
		"@atlassian/react-compiler-gating": "workspace:^",
		"@testing-library/react": "root:*",
		"@types/faker": "root:*",
		"react": "root:*",
		"react-dom": "root:*",
		"swagger-typescript-api": "root:*",
		"ts-morph": "root:*",
		"ts-node": "root:*",
		"wait-for-expect": "root:*"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": [
				"file-and-folder-level"
			]
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"analytics": [
				"analytics-next"
			],
			"design-tokens": [
				"color",
				"spacing"
			],
			"theming": [
				"react-context"
			],
			"ui-components": [
				"lite-mode"
			],
			"deprecation": [
				"no-deprecated-imports"
			],
			"styling": [
				"static",
				"emotion"
			]
		}
	},
	"platform-feature-flags": {
		"enable_edit_team_name_external_type_teams": {
			"type": "boolean"
		},
		"ptc-enable-team-type-permission-enabled": {
			"type": "boolean"
		}
	}
}
