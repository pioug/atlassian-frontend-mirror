{
	"name": "@atlaskit/media-ui",
	"version": "30.3.1",
	"description": "Includes common components and utilities used by other media packages",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": [
		"**/*.compiled.css"
	],
	"atlaskit:src": "src/index.ts",
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlaskit/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Media Exif",
		"website": {
			"name": "Media UI"
		}
	},
	"dependencies": {
		"@atlaskit/afm-i18n-platform-media-media-ui": "root:*",
		"@atlaskit/analytics-next": "workspace:^",
		"@atlaskit/browser-apis": "workspace:^",
		"@atlaskit/button": "workspace:^",
		"@atlaskit/code": "workspace:^",
		"@atlaskit/css": "workspace:^",
		"@atlaskit/flag": "workspace:^",
		"@atlaskit/form": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/icon-file-type": "workspace:^",
		"@atlaskit/locale": "workspace:^",
		"@atlaskit/media-client": "workspace:^",
		"@atlaskit/media-client-react": "workspace:^",
		"@atlaskit/media-common": "workspace:^",
		"@atlaskit/media-state": "workspace:^",
		"@atlaskit/modal-dialog": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/range": "workspace:^",
		"@atlaskit/react-compiler-gating": "workspace:^",
		"@atlaskit/react-ufo": "workspace:^",
		"@atlaskit/select": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/theme": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlaskit/tooltip": "workspace:^",
		"@atlaskit/width-detector": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*",
		"@emotion/styled": "root:*",
		"@popperjs/core": "root:*",
		"blueimp-load-image": "root:*",
		"bytes": "root:*",
		"exenv": "root:*",
		"png-chunks-extract": "root:*",
		"react-render-image": "root:*",
		"use-callback-ref": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-intl": "^5.25.1 || ^6.0.0 || ^7.0.0"
	},
	"devDependencies": {
		"@af/visual-regression": "workspace:^",
		"@atlaskit/analytics-listeners": "workspace:^",
		"@atlaskit/media-test-data": "workspace:^",
		"@atlaskit/ssr": "workspace:^",
		"@atlassian/a11y-jest-testing": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"@atlassian/testing-library": "workspace:^",
		"@testing-library/jest-dom": "root:*",
		"@testing-library/react": "root:*",
		"@types/blueimp-load-image": "root:*",
		"@types/bytes": "root:*",
		"@types/exenv": "root:*",
		"@types/png-chunks-extract": "root:*",
		"jest-emotion": "root:*",
		"jsverify": "root:*",
		"react": "root:*",
		"react-dom": "root:*",
		"react-intl": "root:*",
		"wait-for-expect": "root:*"
	},
	"platform-feature-flags": {
		"platform_media_resume_video_on_token_expiry": {
			"type": "boolean"
		},
		"platform_editor_video_caption_commit": {
			"type": "boolean",
			"referenceOnly": true
		}
	},
	"techstack": {
		"@atlassian/frontend": {
			"circular-dependencies": [
				"file-level"
			]
		},
		"@repo/internal": {
			"design-tokens": [
				"color",
				"spacing"
			],
			"styling": [
				"compiled"
			]
		}
	},
	"exports": {
		".": "./src/index.ts",
		"./abuseModal": "./src/abuseModal/index.ts",
		"./browser": "./src/browser.tsx",
		"./camera": "./src/camera.ts",
		"./classNames": "./src/classNames.ts",
		"./codeViewer": "./src/codeViewer.ts",
		"./customMediaPlayer": "./src/customMediaPlayer/index.tsx",
		"./ellipsify": "./src/ellipsify.tsx",
		"./ellipsify/compiled": "./src/ellipsify-compiled.tsx",
		"./ErroredView": "./src/MediaInlineCard/ErroredView/index.tsx",
		"./errorIcon": "./src/errorIcon.tsx",
		"./formatDate": "./src/formatDate.ts",
		"./formatDuration": "./src/formatDuration.ts",
		"./humanReadableSize": "./src/humanReadableSize.ts",
		"./i18n/*": {
			"publish": null,
			"default": "./src/i18n/*.ts"
		},
		"./imageMetaData": "./src/imageMetaData/index.ts",
		"./imageMetaData/types": "./src/imageMetaData/types.ts",
		"./imageOrientationUtil": "./src/imageMetaData/imageOrientationUtil.ts",
		"./inactivityDetector": "./src/inactivityDetector/inactivityDetector.tsx",
		"./intersectionObserver": "./src/intersectionObserver.ts",
		"./LoadedView": "./src/MediaInlineCard/LoadedView/index.tsx",
		"./LoadingView": "./src/MediaInlineCard/LoadingView/index.tsx",
		"./locales": "./src/locales.ts",
		"./media-type-icon": "./src/media-type-icon.tsx",
		"./media-type-icon/compiled": "./src/media-type-icon-compiled.tsx",
		"./MediaButton": "./src/MediaButton.tsx",
		"./mediaImage": "./src/mediaImage/index.tsx",
		"./mediaPlayer": "./src/customMediaPlayer/mediaPlayer/mediaPlayer.tsx",
		"./mediaPlayer/types": "./src/customMediaPlayer/mediaPlayer/types.ts",
		"./messages": "./src/messages.ts",
		"./mime-type-icon": "./src/mime-type-icon.tsx",
		"./mixins": "./src/mixins.ts",
		"./modalSpinner": "./src/modalSpinner.tsx",
		"./shortcut": "./src/shortcut.tsx",
		"./timeRange": "./src/customMediaPlayer/timeRange.tsx",
		"./truncateText": "./src/truncateText.tsx",
		"./truncateText/compiled": "./src/truncateText-compiled.tsx",
		"./types": "./src/types.ts",
		"./util": "./src/util.ts"
	}
}
