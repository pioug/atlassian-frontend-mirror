		"react": "^18.2.0 || ^19.0.0"
	},
	"devDependencies": {
		"@af/integration-testing": "workspace:^",
		"@af/visual-regression": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/ssr": "workspace:^",
		"@testing-library/react": "root:*",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"techstack": {
		"@atlassian/frontend": {
			"code-structure": [
				"tangerine-next"
