{
	"name": "@atlaskit/editor-synced-block-renderer",
	"version": "10.2.2",
	"description": "SyncedBlockRenderer for @atlaskit/editor-plugin-synced-block",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"ak-postbuild": "ls -d dist/* | grep -v dist/types | xargs -n 1 copyfiles -u 1 -V 'src/**/assets/**/*.svg'"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlaskit/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Editor: Jenga",
		"releaseModel": "continuous",
		"singleton": true
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": false,
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./get-synced-block-renderer": "./src/entry-points/get-synced-block-renderer.tsx",
		"./render-synced-block-content": "./src/entry-points/render-synced-block-content.tsx",
		"./synced-block-node-component-renderer": "./src/entry-points/synced-block-node-component-renderer.tsx",
		"./use-synced-block-node-component": "./src/entry-points/use-synced-block-node-component.tsx"
	},
	"dependencies": {
		"@atlaskit/button": "workspace:^",
		"@atlaskit/css": "workspace:^",
		"@atlaskit/editor-plugin-synced-block": "workspace:^",
		"@atlaskit/editor-synced-block-provider": "workspace:^",
		"@atlaskit/heading": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/icon-lab": "workspace:^",
		"@atlaskit/image": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/react-compiler-gating": "workspace:^",
		"@atlaskit/renderer": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlaskit/tooltip": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*",
		"react-relay": "root:*",
		"relay-runtime": "root:*"
	},
	"peerDependencies": {
		"@atlaskit/editor-common": "workspace:^",
		"react": "^18.2.0",
		"react-intl": "^5.25.1 || ^6.0.0 || ^7.0.0"
	},
	"devDependencies": {
		"react": "root:*",
		"react-intl": "root:*",
		"typescript": "root:*"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": [
				"file-and-folder-level"
			]
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"analytics": [
				"analytics-next"
			],
			"design-tokens": [
				"color"
			],
			"theming": [
				"react-context"
			],
			"ui-components": [
				"lite-mode"
			],
			"deprecation": "no-deprecated-imports",
			"styling": [
				"emotion",
				"emotion"
			],
			"imports": [
				"import-no-extraneous-disable-for-examples-and-docs"
			]
		}
	},
	"platform-feature-flags": {
		"platform_editor_blocks_patch_3": {
			"type": "boolean",
			"referenceOnly": true
		},
		"platform_editor_blocks_patch_4": {
			"type": "boolean",
			"referenceOnly": true
		}
	}
}
