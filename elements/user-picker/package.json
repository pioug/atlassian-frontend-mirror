		"@atlaskit/react-compiler-gating": "workspace:^",
		"@atlaskit/select": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/tag": "workspace:^",
		"@atlaskit/teams-avatar": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlaskit/tooltip": "workspace:^",
		"@atlaskit/ufo": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*",
		"@emotion/react": "root:*",
		"lodash": "root:*",
		"memoize-one": "root:*",
		"uuid": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-intl": "^5.25.1 || ^6.0.0 || ^7.0.0"
	},
	"techstack": {
		"@repo/internal": {
			"design-tokens": [
				"color"
			]
		}
	},
	"keywords": [
		"fabric",
		"ui"
	],
	"platform-feature-flags": {
		"platform-component-visual-refresh": {
			"type": "boolean"
		},
		"twcg-444-invite-usd-improvements-m2-gate": {
			"type": "boolean"
		},
		"product-terminology-refresh": {
			"type": "boolean"
		},
		"platform-dst-lozenge-tag-badge-visual-uplifts": {
			"type": "boolean"
		},
		"enable-sup-archive-experience": {
			"type": "boolean"
		},
		"jsm_routing_recommended_agent_minor_fix": {
			"type": "boolean"
		},
		"jsm-wfo-assignee-recommendation-on-queues": {
