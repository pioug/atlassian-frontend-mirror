		},
		"platform_media_validate_client_id": {
			"type": "boolean"
		},
		"confluence_watermark_admin_ui": {
			"type": "boolean"
		},
		"platform_media_upload_expected_size_header": {
			"type": "boolean"
		},
		"platform_media_filereader_error_surfacing": {
			"type": "boolean",
			"referenceOnly": true
		}
	}
