{
	"name": "@atlaskit/reactions",
	"version": "34.2.7",
	"description": "Reactions component",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"typesVersions": {
		">=4.5 <4.9": {
			"*": [
				"dist/types-ts4.5/*",
				"dist/types-ts4.5/index.d.ts"
			]
		}
	},
	"atlaskit:src": "src/index.ts",
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Editor: Collaboration",
		"website": {
			"name": "Reactions"
		}
	},
	"config": {
		"access": "public"
	},
	"dependencies": {
		"@atlaskit/afm-i18n-platform-elements-reactions": "root:*",
		"@atlaskit/analytics-gas-types": "workspace:^",
		"@atlaskit/analytics-namespaced-context": "workspace:^",
		"@atlaskit/analytics-next": "workspace:^",
		"@atlaskit/avatar": "workspace:^",
		"@atlaskit/button": "workspace:^",
		"@atlaskit/css": "workspace:^",
		"@atlaskit/emoji": "workspace:^",
		"@atlaskit/heading": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/link": "workspace:^",
		"@atlaskit/modal-dialog": "workspace:^",
		"@atlaskit/motion": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/popper": "workspace:^",
		"@atlaskit/popup": "workspace:^",
		"@atlaskit/portal": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/react-ufo": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/tabs": "workspace:^",
		"@atlaskit/theme": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlaskit/tooltip": "workspace:^",
		"@atlaskit/ufo": "workspace:^",
		"@atlaskit/util-service-support": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*",
		"focus-trap": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-intl": "^5.25.1 || ^6.0.0 || ^7.0.0"
	},
	"devDependencies": {
		"@af/visual-regression": "workspace:^",
		"@atlaskit/editor-test-helpers": "workspace:^",
		"@atlaskit/util-data-test": "workspace:^",
		"@atlassian/a11y-jest-testing": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"@atlassian/react-compiler-gating": "workspace:^",
		"@testing-library/dom": "root:*",
		"@testing-library/jest-dom": "root:*",
		"@testing-library/react": "root:*",
		"@testing-library/user-event": "root:*",
		"dotenv": "root:*",
		"es6-promise": "root:*",
		"fetch-mock": "root:*",
		"raf-stub": "root:*",
		"react": "root:*",
		"react-dom": "root:*",
		"react-intl": "root:*",
		"wait-for-expect": "root:*",
		"webpack-dev-server": "root:*"
	},
	"keywords": [
		"fabric",
		"ui"
	],
	"exports": {
		".": "./src/index.ts",
		"./ConnectedReactionPicker": "./src/containers/ConnectedReactionPicker/ConnectedReactionPicker.tsx",
		"./ConnectedReactionsView": "./src/containers/ConnectedReactionsView/ConnectedReactionsView.tsx",
		"./i18n/*": {
			"publish": null,
			"default": "./src/i18n/*.ts"
		},
		"./MemoryReactionsStore": "./src/store/MemoryReactionsStore.ts",
		"./MockReactionsClient": "./src/MockReactionsClient.ts",
		"./reaction": "./src/types/reaction.ts",
		"./Reaction": "./src/components/Reaction.tsx",
		"./ReactionConsumer": "./src/store/ReactionConsumer.tsx",
		"./ReactionPicker": "./src/components/ReactionPicker.tsx",
		"./Reactions": "./src/components/Reactions.tsx",
		"./ReactionServiceClient": "./src/client/ReactionServiceClient.ts",
		"./store": "./src/types/store.ts",
		"./types": "./src/types/index.ts",
		"./useCloseManager": "./src/hooks/useCloseManager.ts"
	},
	"techstack": {
		"@repo/internal": {
			"design-tokens": [
				"color"
			],
			"styling": [
				"compiled"
			]
		},
		"@atlassian/frontend": {
			"tree-shaking": []
		}
	},
	"scripts": {
		"setup-first-time": "yarn run setup-local-config; yarn run setup-env",
		"setup-local-config": "cp -nv local-config-template.ts local-config.ts",
		"setup-env": "cp -nv .env-template .env",
		"start": "cd ../../ && yarn start reactions",
		"test": "cd ../../ && yarn test reactions",
		"typecheck": "cd ../../ && yarn typecheck:package ./packages/elements/reactions",
		"start:dev": "cd ../../ && yarn start:webpack reactions --proxy ./packages/elements/reactions/proxy.ts",
		"start:edge": "cd ../../ && PROXY_TARGET_ENV=edge yarn start:webpack reactions --proxy ./packages/elements/reactions/proxy.ts"
	},
	"platform-feature-flags": {
		"platform_reactions_optimistic_url": {
			"type": "boolean"
		},
		"platform-component-visual-refresh": {
			"type": "boolean"
		},
		"platform_optimistic_reaction_emoji": {
			"type": "boolean"
		},
		"jfp_a11y_team_comment_actions_semantic": {
			"type": "boolean"
		},
		"platform_suppression_removal_fix_reactions": {
			"type": "boolean"
		},
		"a11y-fix-reaction-picker-aria-owns": {
			"type": "boolean"
		},
		"platform_reactions_view_more_styling_fix": {
			"type": "boolean"
		},
		"platform_a11y_fixes_reaction_emoji": {
			"type": "boolean"
		}
	},
	"sideEffects": [
		"*.compiled.css"
	]
}
