{
	"name": "@atlaskit/analytics-namespaced-context",
	"version": "8.1.0",
	"description": "Provides a namespace for AnalyticsContext data (@atlaskit/analytics-next)",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./MediaAnalyticsContext": "./src/MediaAnalyticsContext.tsx",
		"./NavigationAnalyticsContext": "./src/NavigationAnalyticsContext.tsx",
		"./PeopleTeamsAnalyticsContext": "./src/PeopleTeamsAnalyticsContext.tsx",
		"./RecentWorkAnalyticsContext": "./src/RecentWorkAnalyticsContext.tsx",
		"./FabricEditorAnalyticsContext": "./src/FabricEditorAnalyticsContext.tsx",
		"./AtlasAnalyticsContext": "./src/AtlasAnalyticsContext.tsx",
		"./LinkingPlatformAnalyticsContext": "./src/LinkingPlatformAnalyticsContext.tsx",
		"./PostOfficeAnalyticsContext": "./src/PostOfficeAnalyticsContext.tsx",
		"./AIMateAnalyticsContext": "./src/entry-points/AIMateAnalyticsContext.tsx",
		"./AVPAnalyticsContext": "./src/entry-points/AVPAnalyticsContext.tsx",
		"./FabricElementsAnalyticsContext": "./src/entry-points/FabricElementsAnalyticsContext.tsx",
		"./GrowthAnalyticsContext": "./src/entry-points/GrowthAnalyticsContext.tsx",
		"./NotificationsAnalyticsContext": "./src/entry-points/NotificationsAnalyticsContext.tsx",
		"./OmniChannelAnalyticsContext": "./src/entry-points/OmniChannelAnalyticsContext.tsx",
		"./RovoExtensionAnalyticsContext": "./src/entry-points/RovoExtensionAnalyticsContext.tsx",
		"./TownsquareHomeAnalyticsContext": "./src/entry-points/TownsquareHomeAnalyticsContext.tsx"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlaskit/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "UIP Frontend Observability"
	},
	"config": {
		"access": "public"
	},
	"dependencies": {
		"@atlaskit/analytics-next": "workspace:^",
		"@atlaskit/react-compiler-gating": "workspace:^",
		"@babel/runtime": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@testing-library/react": "root:*",
		"react": "root:*"
	},
	"keywords": [
		"fabric",
		"ui"
	]
}
