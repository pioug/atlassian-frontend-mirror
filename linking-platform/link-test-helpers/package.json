{
	"name": "@atlaskit/link-test-helpers",
	"version": "11.0.1",
	"description": "Collection of test helpers used in linking platform examples and specs",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
