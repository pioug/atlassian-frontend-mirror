{
	"name": "@atlaskit/react-select",
	"version": "3.16.2",
	"description": "A forked version of react-select to only be used in atlaskit/select",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"atlassian": {
		"team": "Design System Team"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": [
		"**/*.compiled.css"
	],
	"atlaskit:src": "src/index.tsx",
	"exports": {
		".": "./src/index.tsx",
		"./accessibility": "./src/entry-points/accessibility.tsx",
		"./async": "./src/entry-points/async.tsx",
		"./async-creatable": "./src/entry-points/async-creatable.tsx",
		"./base": "./src/entry-points/base.tsx",
		"./clear-indicator": "./src/entry-points/clear-indicator.tsx",
		"./components": "./src/entry-points/components.tsx",
		"./control": "./src/entry-points/control.tsx",
		"./creatable": "./src/entry-points/creatable.tsx",
		"./dropdown-indicator": "./src/entry-points/dropdown-indicator.tsx",
		"./filters": "./src/entry-points/filters.tsx",
		"./group": "./src/entry-points/group.tsx",
		"./group-heading": "./src/entry-points/group-heading.tsx",
		"./indicators-container": "./src/entry-points/indicators-container.tsx",
		"./input": "./src/entry-points/input.tsx",
		"./loading-indicator": "./src/entry-points/loading-indicator.tsx",
		"./menu": "./src/entry-points/menu.tsx",
		"./menu-list": "./src/entry-points/menu-list.tsx",
		"./menu-portal": "./src/entry-points/menu-portal.tsx",
		"./multi-value": "./src/entry-points/multi-value.tsx",
		"./multi-value-remove": "./src/entry-points/multi-value-remove.tsx",
		"./option": "./src/entry-points/option.tsx",
		"./placeholder": "./src/entry-points/placeholder.tsx",
		"./select-container": "./src/entry-points/select-container.tsx",
		"./single-value": "./src/entry-points/single-value.tsx",
		"./state-manager": "./src/entry-points/state-manager.tsx",
		"./styles": "./src/entry-points/styles.tsx",
		"./types": "./src/entry-points/types.tsx",
		"./use-async": "./src/entry-points/use-async.tsx",
		"./use-creatable": "./src/entry-points/use-creatable.tsx",
		"./use-state-manager": "./src/entry-points/use-state-manager.tsx",
		"./value-container": "./src/entry-points/value-container.tsx"
	},
	"dependencies": {
		"@atlaskit/ds-lib": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/layering": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/tag": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*",
		"@floating-ui/dom": "root:*",
		"memoize-one": "root:*",
		"use-isomorphic-layout-effect": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"devDependencies": {
		"@af/accessibility-testing": "workspace:^",
		"@atlaskit/checkbox": "workspace:^",
		"@atlaskit/form": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"@testing-library/react": "root:*",
		"@testing-library/user-event": "root:*",
		"jest-in-case": "root:*",
		"react": "root:*",
		"react-dom": "root:*"
	},
	"platform-feature-flags": {
		"custom-interactive-elements-not-keyboard-focusable": {
			"type": "boolean"
		},
		"platform_dst_select_menu_close_on_blur": {
			"type": "boolean"
		},
		"platform_fix_input_component_styling": {
			"type": "boolean"
		},
		"platform_fix_autocomplete_aria_for_select": {
			"type": "boolean"
		},
		"select_issearchable_aria-readonly_fix": {
			"type": "boolean"
		},
		"platform-dst-shape-theme-default": {
			"type": "boolean"
		},
		"platform-dst-lozenge-tag-badge-visual-uplifts": {
			"type": "boolean"
		}
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": "file-and-folder-level"
		},
		"@repo/internal": {
			"design-system": "v1",
			"dom-events": "use-bind-event-listener",
			"analytics": "analytics-next",
			"ui-components": [
				"lite-mode"
			],
			"deprecation": "no-deprecated-imports",
			"styling": [
				"static",
				"compiled"
			]
		}
	},
	"homepage": "https://atlassian.design/components",
	"typesVersions": {
		">=4.5 <4.9": {
			"*": [
				"dist/types-ts4.5/*",
				"dist/types-ts4.5/index.d.ts"
			]
		}
	}
}
