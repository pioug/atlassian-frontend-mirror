{
	"name": "@atlaskit/media-common",
	"version": "14.0.0",
	"description": "Includes common utilities used by other media packages",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": false,
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./analytics/types": "./src/analytics/types.ts",
		"./analytics": "./src/analytics/index.ts",
		"./await-error": "./src/test-helpers/await-error.ts",
		"./clientIdCache": "./src/copyIntent/clientIdCache.ts",
		"./constants": "./src/analytics/constants.ts",
		"./docs": "./src/docs/index.ts",
		"./downloadUrl": "./src/downloadUrl.ts",
		"./flushPromises": "./src/test-helpers/flushPromises.ts",
		"./getJest": "./src/test-helpers/getJest.ts",
		"./helpers": "./src/utils/helpers.ts",
		"./isMimeTypeSupportedByBrowser": "./src/mediaTypeUtils/isMimeTypeSupportedByBrowser.ts",
		"./isMimeTypeSupportedByServer": "./src/mediaTypeUtils/isMimeTypeSupportedByServer.ts",
		"./isExcelFile": "./src/mediaTypeUtils/isExcelFile.ts",
		"./isZipMimeType": "./src/mediaTypeUtils/isZipMimeType.ts",
		"./isValidUuid": "./src/utils/isValidUuid.ts",
		"./jestHelpers": "./src/test-helpers/jestHelpers.ts",
		"./media-use-only": "./src/docs/media-use-only.tsx",
		"./mediaFeatureFlags": "./src/mediaFeatureFlags/index.ts",
		"./mediaTypeUtils": "./src/mediaTypeUtils/index.ts",
		"./nextTick": "./src/test-helpers/nextTick.ts",
		"./rxjs-notice": "./src/docs/rxjs-notice.tsx",
		"./sanitisePayload": "./src/analytics/sanitisePayload.ts",
		"./singleton-notice": "./src/docs/singleton-notice.tsx",
		"./smallImageURI": "./src/test-helpers/dataURIs/smallImageURI.ts",
		"./smallTransparentImageURI": "./src/test-helpers/dataURIs/smallTransparentImageURI.ts",
		"./tallImageURI": "./src/test-helpers/dataURIs/tallImageURI.ts",
		"./test-helpers": "./src/test-helpers/index.ts",
		"./timeoutPromise": "./src/test-helpers/timeoutPromise.ts",
		"./types": "./src/mediaFeatureFlags/types.ts",
		"./useStaticCallback": "./src/hooks/useStaticCallback.ts",
		"./videoPreviewURI": "./src/test-helpers/dataURIs/videoPreviewURI.ts",
		"./videoURI": "./src/test-helpers/dataURIs/videoURI.ts",
		"./vr-test-small-image": "./src/test-helpers/dataURIs/vr_test_small_image.ts",
		"./wideImageURI": "./src/test-helpers/dataURIs/wideImageURI.ts",
		"./wideTransparentImageURI": "./src/test-helpers/dataURIs/wideTransparentImageURI.ts",
		"./withMediaAnalyticsContext": "./src/analytics/withMediaAnalyticsContext.tsx",
		"./mediaEnvUtils": "./src/utils/mediaEnvUtils.ts"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Media Exif",
		"website": {
			"name": "Media Common"
		}
	},
	"dependencies": {
		"@atlaskit/analytics-gas-types": "workspace:^",
		"@atlaskit/analytics-namespaced-context": "workspace:^",
		"@atlaskit/analytics-next": "workspace:^",
		"@atlaskit/link": "workspace:^",
		"@atlaskit/section-message": "workspace:^",
		"@babel/runtime": "root:*",
		"immer": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"devDependencies": {
		"@atlassian/react-compiler-gating": "workspace:^",
		"@atlassian/testing-library": "workspace:^",
		"react": "root:*",
		"react-dom": "root:*"
	}
