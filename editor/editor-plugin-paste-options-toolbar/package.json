	},
	"dependencies": {
		"@atlaskit/css": "workspace:^",
		"@atlaskit/dropdown-menu": "workspace:^",
		"@atlaskit/editor-markdown-transformer": "workspace:^",
		"@atlaskit/editor-plugin-analytics": "workspace:^",
		"@atlaskit/editor-plugin-paste": "workspace:^",
		"@atlaskit/editor-plugin-ui-control-registry": "workspace:^",
		"@atlaskit/editor-prosemirror": "workspace:^",
		"@atlaskit/editor-shared-styles": "workspace:^",
		"@atlaskit/editor-toolbar": "workspace:^",
		"@atlaskit/editor-ui-control-model": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/tmp-editor-statsig": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*",
		"@emotion/react": "root:*"
	},
	"peerDependencies": {
		"@atlaskit/editor-common": "workspace:^",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-intl": "^5.25.1 || ^6.0.0 || ^7.0.0"
	},
	"devDependencies": {
		"@testing-library/react": "root:*",
		"react": "root:*",
		"react-dom": "root:*",
		"react-intl": "root:*",
		"wait-for-expect": "root:*"
	},
	"platform-feature-flags": {
		"platform_editor_agent_mentions": {
			"type": "experiment"
		},
		"platform_editor_paste_actions_menu_exposure": {
			"type": "boolean"
		},
		"platform_editor_paste_actions_menu_v2_exposure": {
			"type": "boolean"
		}
	},
	"techstack": {
		"@atlassian/frontend": {
			"code-structure": [
				"editor-plugin"
			],
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": [
				"file-and-folder-level"
			]
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"analytics": [
				"analytics-next"
			],
			"design-tokens": [
				"color"
			],
			"theming": [
				"react-context"
			],
			"ui-components": [
				"lite-mode"
			],
			"deprecation": "no-deprecated-imports",
			"styling": [
				"emotion",
				"emotion"
			],
			"imports": [
				"import-no-extraneous-disable-for-examples-and-docs"
			]
