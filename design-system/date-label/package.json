						"type": "beta",
						"description": "New and ready to use. We'll provide comms and support for any major changes."
					}
				}
			]
		}
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-monorepo",
	"main": "dist/cjs/entry-points/date-label.js",
