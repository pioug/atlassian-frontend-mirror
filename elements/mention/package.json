{
	"atlaskit:src": "src/index.ts",
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlaskit/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Search Platform: Search Experience",
		"slack": {
			"channel": "#search-plex-prs",
			"notifications": {
				"mergedPR": {
					"message": "A PR was merged in @atlaskit/mention without maintainer approval."
				}
			}
		},
		"website": {
			"name": "Mention"
		}
	},
	"author": "Atlassian Pty Ltd",
	"config": {
		"access": "public"
	},
	"dependencies": {
		"@atlaskit/afm-i18n-platform-elements-mention": "root:*",
		"@atlaskit/analytics-gas-types": "workspace:^",
		"@atlaskit/analytics-next": "workspace:^",
		"@atlaskit/avatar": "workspace:^",
		"@atlaskit/focus-ring": "workspace:^",
		"@atlaskit/heading": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/lozenge": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/react-compiler-gating": "workspace:^",
		"@atlaskit/tag": "workspace:^",
		"@atlaskit/teams-avatar": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlaskit/tooltip": "workspace:^",
		"@atlaskit/ufo": "workspace:^",
		"@atlaskit/util-service-support": "workspace:^",
		"@babel/runtime": "root:*",
		"@emotion/react": "root:*",
		"@emotion/styled": "root:*",
		"lodash": "root:*",
		"uuid": "root:*"
	},
	"description": "A React component used to display user profiles in a list for 'Mention' functionality",
	"devDependencies": {
		"@af/integration-testing": "workspace:^",
		"@af/search-test-utils": "workspace:^",
		"@af/visual-regression": "workspace:^",
		"@atlassian/a11y-jest-testing": "workspace:^",
		"@atlassian/a11y-playwright-testing": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"@atlassian/testing-library": "workspace:^",
		"@testing-library/react": "root:*",
		"@testing-library/user-event": "root:*",
		"@types/query-string": "root:*",
		"@types/serialize-javascript": "root:*",
		"enzyme": "root:*",
		"es6-promise": "root:*",
		"exenv": "root:*",
		"fetch-mock": "root:*",
		"query-string": "root:*",
		"react": "root:*",
		"react-dom": "root:*",
		"react-intl": "root:*",
		"serialize-javascript": "root:*"
	},
	"exports": {
		".": "./src/index.ts",
		"./analytics": "./src/util/analytics.ts",
		"./constants": "./src/_constants.ts",
		"./context-mention-resource": "./src/api/ContextMentionResource.ts",
		"./element": "./src/element.ts",
		"./i18n/*": {
			"publish": null,
			"default": "./src/i18n/*.ts"
		},
		"./item": "./src/item.ts",
		"./mention": "./src/components/Mention/index.tsx",
		"./mention-item/styles": "./src/components/MentionItem/styles.ts",
		"./mention-item": "./src/components/MentionItem/index.tsx",
		"./mention-list": "./src/components/MentionList/index.tsx",
		"./mention-name-client": "./src/api/MentionNameClient.ts",
		"./mention-name-resolver": "./src/api/MentionNameResolver.ts",
		"./mention-picker": "./src/components/MentionPicker/index.tsx",
		"./mention-resource": "./src/api/MentionResource.ts",
		"./presence-resource": "./src/api/PresenceResource.ts",
		"./resource": "./src/resource.ts",
		"./resourced-mention": "./src/components/Mention/ResourcedMention.tsx",
		"./resourced-mention-list": "./src/components/ResourcedMentionList/index.tsx",
		"./shared-styles": "./src/shared-styles.ts",
		"./team-resource": "./src/team-resource.ts",
		"./team-mention-resource": "./src/api/TeamMentionResource.ts",
		"./typeahead": "./src/typeahead.ts",
		"./types": "./src/types.ts"
	},
	"keywords": [
		"ui",
		"mention",
		"fabric",
		"teams"
	],
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"name": "@atlaskit/mention",
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-intl": "^5.25.1 || ^6.0.0 || ^7.0.0"
	},
	"platform-feature-flags": {
		"rovo_chat_agent_selection": {
			"type": "boolean",
			"referenceOnly": true
		},
		"jira_ai_agent_avatar_issue_view_comment_mentions": {
			"type": "boolean"
		},
		"platform-dst-lozenge-tag-badge-visual-uplifts": {
			"type": "boolean"
		}
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"sideEffects": [
		"*.compiled.css"
	],
	"techstack": {
		"@repo/internal": {
			"deprecation": "no-deprecated-imports",
			"design-tokens": [
				"color"
			],
			"styling": "emotion"
		}
	},
	"types": "dist/types/index.d.ts",
	"version": "27.5.0"
}
