{
	"name": "@atlaskit/media-avatar-picker",
	"version": "28.0.1",
	"description": "A component to select, drag and resize image avatars. It also provides a default list of predefined avatars.",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": [
		"**/*.compiled.css"
	],
	"atlaskit:src": "src/index.tsx",
	"exports": {
		".": "./src/index.tsx",
		"./avatar-list": "./src/avatar-list/index.tsx",
		"./avatar-picker-dialog-loader": "./src/avatar-picker-dialog/avatar-picker-dialog-loader.tsx",
		"./exportCroppedImage": "./src/image-navigator/exportCroppedImage.ts",
		"./image-cropper": "./src/image-cropper/index.tsx",
		"./image-navigator": "./src/image-navigator/index.tsx",
		"./images": "./src/image-navigator/images.ts",
		"./slider": "./src/image-navigator/slider.tsx",
		"./viewport": "./src/viewport/viewport.ts"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Media Exif",
		"website": {
			"name": "Media Avatar Picker"
		}
	},
	"dependencies": {
		"@atlaskit/button": "workspace:^",
		"@atlaskit/css": "workspace:^",
		"@atlaskit/flag": "workspace:^",
		"@atlaskit/form": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/media-ui": "workspace:^",
		"@atlaskit/modal-dialog": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/range": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/textfield": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlaskit/visually-hidden": "workspace:^",
		"@atlassian/react-compiler-gating": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*",
		"exenv": "root:*",
		"react-error-boundary": "root:*"
	},
	"peerDependencies": {
		"@emotion/react": "^11.7.1",
		"react": "^18.2.0",
		"react-intl": "^5.25.1 || ^6.0.0 || ^7.0.0"
	},
	"devDependencies": {
		"@atlaskit/media-core": "workspace:^",
		"@atlaskit/media-test-helpers": "workspace:^",
		"@atlassian/a11y-jest-testing": "workspace:^",
		"@atlassian/testing-library": "workspace:^",
		"@testing-library/react": "root:*",
		"@testing-library/user-event": "root:*",
		"@types/exenv": "root:*",
		"react": "root:*",
		"react-dom": "root:*",
		"react-intl": "root:*"
	},
	"platform-feature-flags": {
		"platform_media_package_react19_lifecycle_fix": {
			"type": "boolean"
		}
	},
	"techstack": {
		"@repo/internal": {
			"design-tokens": [
				"color",
				"spacing"
			],
			"styling": [
				"compiled"
			]
		}
	}
}
