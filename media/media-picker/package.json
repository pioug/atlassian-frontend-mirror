{
	"name": "@atlaskit/media-picker",
	"version": "72.0.1",
	"description": "Library for handling file uploads",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"sideEffects": false,
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./browser": "./src/components/browser/index.tsx",
		"./clipboard": "./src/components/clipboard/index.tsx",
		"./components/types": "./src/components/types.ts",
		"./dropzone": "./src/components/dropzone/index.tsx",
		"./plugin": "./src/domain/plugin.ts",
		"./preview": "./src/domain/preview.ts",
		"./types": "./src/types.ts"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Media Exif",
		"website": {
			"name": "Media Picker"
		}
	},
	"dependencies": {
		"@atlaskit/analytics-next": "workspace:^",
		"@atlaskit/flag": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/media-client": "workspace:^",
		"@atlaskit/media-client-react": "workspace:^",
		"@atlaskit/media-common": "workspace:^",
		"@atlaskit/media-ui": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlaskit/ufo": "workspace:^",
		"@babel/runtime": "root:*",
		"eventemitter2": "root:*",
		"exenv": "root:*",
		"perf-marks": "root:*",
		"uuid": "root:*"
	},
	"peerDependencies": {
		"@atlaskit/media-core": "workspace:^",
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-intl": "^5.25.1 || ^6.0.0 || ^7.0.0"
	},
	"devDependencies": {
		"@atlaskit/analytics-listeners": "workspace:^",
		"@atlaskit/analytics-namespaced-context": "workspace:^",
		"@atlaskit/button": "workspace:^",
		"@atlaskit/media-core": "workspace:^",
		"@atlaskit/media-test-helpers": "workspace:^",
		"@atlaskit/ssr": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"@atlassian/react-compiler-gating": "workspace:^",
		"@atlassian/testing-library": "workspace:^",
		"@atlassian/ufo": "workspace:^",
		"@babel/plugin-proposal-numeric-separator": "root:*",
		"@emotion/react": "root:*",
		"@testing-library/dom": "root:*",
		"@testing-library/react": "root:*",
		"@testing-library/user-event": "root:*",
		"@types/exenv": "root:*",
		"@types/react": "root:*",
		"fetch-mock": "root:*",
		"identity-obj-proxy": "root:*",
		"react": "root:*",
		"react-dom": "root:*",
		"react-intl": "root:*",
		"wait-for-expect": "root:*"
	},
	"techstack": {
		"@repo/internal": {
			"design-tokens": [
				"color",
				"spacing"
			]
		}
	},
	"platform-feature-flags": {
		"platform_media_package_react19_lifecycle_fix": {
			"type": "boolean"
		},
		"platform_media_picker_upload_batching": {
			"type": "boolean"
		},
		"platform_media_filereader_error_surfacing": {
			"type": "boolean"
		}
	}
}
