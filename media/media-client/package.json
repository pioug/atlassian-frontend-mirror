		"./media-subscribable/types": "./src/utils/mediaSubscribable/types.ts",
		"./media": "./src/models/media.ts",
		"./media-core": "./src/media-core.ts",
		"./media-state": "./src/media-state.ts",
		"./mobile-upload": "./src/models/mobile-upload.ts",
		"./polling": "./src/utils/polling/index.ts",
		"./polling/errors": "./src/utils/polling/errors.ts",
		"./polling/types": "./src/utils/polling/types.ts",
		"./request": "./src/utils/request/index.ts",
