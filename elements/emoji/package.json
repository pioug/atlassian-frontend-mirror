{
	"name": "@atlaskit/emoji",
	"version": "71.5.3",
	"description": "Fabric emoji React components",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": [
		"*.compiled.css"
	],
	"atlaskit:src": "src/index.ts",
	"atlassian": {
		"team": "Editor: Collaboration",
		"website": {
			"name": "Emoji"
		},
		"react-compiler": {
			"disabled": true
		}
	},
	"config": {
		"access": "public"
	},
	"dependencies": {
		"@atlaskit/afm-i18n-platform-elements-emoji": "root:*",
		"@atlaskit/analytics-next": "workspace:^",
		"@atlaskit/browser-apis": "workspace:^",
		"@atlaskit/button": "workspace:^",
		"@atlaskit/css": "workspace:^",
		"@atlaskit/feature-gate-js-client": "workspace:^",
		"@atlaskit/form": "workspace:^",
		"@atlaskit/heading": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/icon-lab": "workspace:^",
		"@atlaskit/image": "workspace:^",
		"@atlaskit/media-client": "workspace:^",
		"@atlaskit/media-client-react": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/pragmatic-drag-and-drop": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/radio": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/textfield": "workspace:^",
		"@atlaskit/theme": "workspace:^",
		"@atlaskit/tmp-editor-statsig": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlaskit/tooltip": "workspace:^",
		"@atlaskit/ufo": "workspace:^",
		"@atlaskit/util-service-support": "workspace:^",
		"@atlaskit/visually-hidden": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*",
		"@tanstack/react-virtual": "root:*",
		"js-search": "root:*",
		"lru_map": "root:*",
		"react-focus-lock": "root:*",
		"react-intersection-observer": "root:*",
		"react-loadable": "root:*",
		"use-debounce": "root:*",
		"uuid": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0",
		"react-intl": "^5.25.1 || ^6.0.0 || ^7.0.0"
	},
	"devDependencies": {
		"@af/integration-testing": "workspace:^",
		"@af/visual-regression": "workspace:^",
		"@atlaskit/media-core": "workspace:^",
		"@atlaskit/ssr": "workspace:^",
		"@atlassian/a11y-jest-testing": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"@emotion/jest": "root:*",
		"@testing-library/dom": "root:*",
		"@testing-library/jest-dom": "root:*",
		"@testing-library/react": "root:*",
		"@testing-library/user-event": "root:*",
		"@types/js-search": "root:*",
		"dotenv": "root:*",
		"enzyme": "root:*",
		"es6-promise": "root:*",
		"fetch-mock": "root:*",
		"jest-axe": "root:*",
		"p-wait-for": "root:*",
		"react": "root:*",
		"react-addons-perf": "root:*",
		"react-dom": "root:*",
		"react-intl": "root:*",
		"react-test-renderer": "root:*",
		"rxjs": "root:*",
		"sinon": "root:*",
		"wait-for-expect": "root:*",
		"webpack-dev-server": "root:*"
	},
	"keywords": [
		"fabric",
		"ui"
	],
	"exports": {
		".": "./src/index.ts",
		"./admin": "./src/admin.ts",
		"./analytics": "./src/util/analytics/analytics.ts",
		"./categories": "./src/components/picker/categories.ts",
		"./constants": "./src/util/constants.ts",
		"./element": "./src/element.ts",
		"./emoji": "./src/components/common/Emoji.tsx",
		"./emoji-common-provider": "./src/context/EmojiCommonProvider.tsx",
		"./emoji-context-provider": "./src/context/EmojiContextProvider.tsx",
		"./emoji-id-to-emoji": "./src/util/emojiIdToEmoji.ts",
		"./emoji-loader": "./src/api/EmojiLoader.ts",
		"./emoji-picker": "./src/components/picker/EmojiPicker.tsx",
		"./emoji-placeholder": "./src/components/common/EmojiPlaceholder.tsx",
		"./emoji-repository": "./src/api/EmojiRepository.ts",
		"./emoji-resource": "./src/api/EmojiResource.ts",
		"./emoji-type-ahead": "./src/components/typeahead/EmojiTypeAhead.tsx",
		"./emoji-type-ahead-item": "./src/components/typeahead/EmojiTypeAheadItem.tsx",
		"./emoji-type-ahead-list": "./src/components/typeahead/EmojiTypeAheadList.tsx",
		"./emoji-uploader": "./src/components/uploader/EmojiUploader.tsx",
		"./emoji-utils": "./src/api/EmojiUtils.ts",
		"./i18n/*": {
			"publish": null,
			"default": "./src/i18n/*.ts"
		},
		"./picker": "./src/picker.ts",
		"./resource": "./src/resource.ts",
		"./resourced-emoji": "./src/components/common/ResourcedEmoji.tsx",
		"./sampling-ufo": "./src/util/analytics/samplingUfo.ts",
		"./styles": "./src/components/common/styles.ts",
		"./type-helpers": "./src/util/type-helpers.ts",
		"./typeahead": "./src/typeahead.ts",
		"./types": "./src/types.ts",
		"./ufo-experiences": "./src/util/analytics/ufoExperiences.ts",
		"./usage-frequency-tracker": "./src/api/internal/UsageFrequencyTracker.ts",
		"./use-emoji": "./src/hooks/useEmoji.ts",
		"./use-emoji-context": "./src/hooks/useEmojiContext.ts",
		"./utils": "./src/utils.ts"
	},
	"techstack": {
		"@repo/internal": {
			"design-tokens": [
				"color"
			],
			"styling": [
				"compiled"
			]
		}
	},
	"platform-feature-flags": {
		"platform_index_emoji_just_in_time": {
			"type": "boolean"
		},
		"platform_emoji_prevent_img_src_changing": {
			"type": "boolean"
		},
		"platform_emoji_prevent_img_src_changing_all": {
			"type": "boolean"
		},
		"platform_suppression_removal_fix_reactions": {
			"type": "boolean"
		},
		"platform_change_emoji_button_label": {
			"type": "boolean"
		},
		"increase-emoji-client-upload-timeout": {
			"type": "boolean"
		},
		"platform_emoji_keep_picker_open_on_upload": {
			"type": "boolean"
		},
		"use-elements-stargate-emoji-path": {
			"type": "boolean"
		},
		"platform_emoji_a11y_category_heading": {
			"type": "boolean"
		},
		"platform_a11y_fixes_reaction_emoji": {
			"type": "boolean"
		}
	},
	"platform-experiments": {
		"platform_teamoji_26_refresh_emoji_picker": {
			"param": "isEnabled",
			"defaultValue": false
		}
	},
	"scripts": {
		"setup-first-time": "yarn run setup-local-config; yarn run setup-env",
		"setup-local-config": "cp -nv local-config-template.ts local-config.ts",
		"setup-env": "cp -nv .env-template .env",
		"start": "cd ../../ && yarn start emoji",
		"test": "cd ../../ && yarn test emoji",
		"typecheck": "cd ../../ && yarn typecheck:package ./packages/elements/emoji",
		"start:dev": "cd ../../ && yarn start:webpack emoji --proxy ./packages/elements/emoji/proxy.ts",
		"start:edge": "cd ../../ && PROXY_TARGET_ENV=edge yarn start:webpack emoji --proxy ./packages/elements/emoji/proxy.ts"
	}
}
