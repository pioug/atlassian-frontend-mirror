{
	"name": "@atlaskit/editor-smart-link-draggable",
	"version": "0.1.0",
	"description": "Drag-and-drop support for smart link cards. Provides a draggable wrapper component, shared constants, types, and utilities for smart link DnD between editor/renderer (drag sources) and the content tree (drop target).",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"typesVersions": {
		">=4.5 <4.9": {
			"*": [
				"dist/types-ts4.5/*",
				"dist/types-ts4.5/index.d.ts"
			]
		}
	},
	"atlaskit:src": "src/index.tsx",
	"exports": {
		".": "./src/index.tsx"
	},
	"atlassian": {
		"team": "Editor",
		"website": {
			"name": "SmartLinkDraggable"
		}
	},
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"dependencies": {
		"@atlaskit/css": "workspace:^",
		"@atlaskit/link-extractors": "workspace:^",
		"@atlaskit/link-provider": "workspace:^",
		"@atlaskit/linking-types": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/pragmatic-drag-and-drop": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/smart-card": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"devDependencies": {
		"@testing-library/react": "root:*"
	},
	"platform-feature-flags": {
		"confluence_dnd_smart_link_from_content": {
			"type": "boolean"
		}
	}
}
