{
	"extends": "../tsconfig",
	"compilerOptions": {
		"target": "es2015",
		"paths": {},
		"downlevelIteration": true
	},
	"include": ["../src/**/*.ts", "../src/**/*.tsx"],
	"exclude": [
		"../src/**/__tests__/*",
		"../src/**/*.test.*",
		"../src/**/test.*",
		"../src/**/examples.*",
		"../src/**/examples/*",
		"../src/**/examples/**/*",
		"../src/**/*.stories.*",
		"../src/**/stories/*",
		"../src/**/stories/**/*"
	]
}
