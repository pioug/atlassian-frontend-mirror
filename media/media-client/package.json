		"website": {
			"name": "Media Client"
		}
	},
	"dependencies": {
		"@atlaskit/atlassian-context": "workspace:^",
		"@atlaskit/chunkinator": "workspace:^",
		"@atlaskit/media-common": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/tmp-editor-statsig": "workspace:^",
		"@babel/runtime": "root:*",
		"dataloader": "root:*",
		"deep-equal": "root:*",
		"eventemitter2": "root:*",
		"js-sha256": "root:*",
		"lru_map": "root:*",
		"rusha": "root:*",
		"rxjs": "root:*",
		"uuid": "root:*",
		"xstate": "root:*"
	},
	"peerDependencies": {
		"@atlaskit/media-core": "workspace:^",
		"@atlaskit/media-state": "workspace:^"
	},
	"devDependencies": {
		"@atlaskit/media-core": "workspace:^",
		"@atlaskit/media-state": "workspace:^",
		"@atlaskit/ssr": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlassian/a11y-jest-testing": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"@emotion/react": "root:*",
		"@types/deep-equal": "root:*",
		"fetch-mock": "root:*",
		"react": "root:*",
		"react-dom": "root:*"
	},
	"techstack": {
		"@atlassian/frontend": {
			"circular-dependencies": [
				"file-level"
			]
		},
		"@repo/internal": {
			"design-tokens": [
				"color",
				"spacing"
			]
		}
	},
	"platform-feature-flags": {
		"platform_media_cdn_single_host": {
			"type": "boolean"
		},
		"platform_media_cdn_delivery": {
			"type": "boolean"
		},
		"platform_media_path_based_route": {
			"type": "boolean"
		},
		"platform_media_retry_edge_error": {
