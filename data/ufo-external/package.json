{
	"name": "@atlaskit/ufo",
	"version": "0.5.0",
	"description": "UFO external part",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"atlassian": {
		"team": "UIP Frontend Observability",
		"website": {
			"name": "UFO"
		}
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"typesVersions": {
		">=4.5 <4.9": {
			"*": [
				"dist/types-ts4.5/*",
				"dist/types-ts4.5/index.d.ts"
			]
		}
	},
	"sideEffects": false,
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./global-stream-buffer": "./src/global-stream-buffer/index.ts",
		"./logger": "./src/logger/index.ts",
		"./platform-client": "./src/platform-client/index.ts",
		"./types": "./src/types.ts",
		"./buildVersion": "./src/entry-points/buildVersion.ts",
		"./concurrent-experience": "./src/entry-points/concurrent-experience.ts",
		"./experience": "./src/entry-points/experience.ts",
		"./experience-state": "./src/entry-points/experience-state.ts",
		"./experience-types": "./src/entry-points/experience-types.ts",
		"./global-page-load-experience": "./src/entry-points/global-page-load-experience.ts",
		"./until-helpers": "./src/entry-points/until-helpers.ts",
		"./visibility-change-observer": "./src/entry-points/visibility-change-observer.ts"
	},
	"dependencies": {
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@babel/runtime": "root:*",
		"uuid": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": [
				"file-and-folder-level"
			]
		},
		"@repo/internal": {
			"deprecation": [
				"no-deprecated-imports"
			]
		}
	},
	"platform-feature-flags": {},
	"devDependencies": {
		"react": "root:*"
	}
}
