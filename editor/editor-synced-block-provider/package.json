		"./syncBlockProvider": "./src/entry-points/syncBlockProvider.ts",
		"./syncBlockStoreManager": "./src/entry-points/syncBlockStoreManager.ts",
		"./tokenRouting": "./src/entry-points/tokenRouting.ts",
		"./types": "./src/entry-points/providers-types.ts",
		"./useFetchSyncBlockData": "./src/entry-points/useFetchSyncBlockData.ts",
		"./useFetchSyncBlockTitle": "./src/entry-points/useFetchSyncBlockTitle.ts",
		"./useHandleContentChanges": "./src/entry-points/useHandleContentChanges.ts",
		"./utils": "./src/entry-points/utils.ts",
		"./utils/resourceId": "./src/entry-points/resourceId.ts",
		"./validValue": "./src/entry-points/validValue.ts"
	},
	"dependencies": {
		"@atlaskit/adf-utils": "workspace:^",
		"@atlaskit/editor-json-transformer": "workspace:^",
		"@atlaskit/editor-prosemirror": "workspace:^",
		"@atlaskit/node-data-provider": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/tmp-editor-statsig": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*",
		"graphql-ws": "root:*",
		"lodash": "root:*",
		"raf-schd": "root:*",
		"uuid": "root:*"
	},
	"peerDependencies": {
		"@atlaskit/editor-common": "workspace:^",
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@testing-library/react": "root:*",
		"react-dom": "root:*"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": [
				"file-and-folder-level"
			]
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"analytics": [
				"analytics-next"
			],
			"design-tokens": [
				"color"
			],
			"theming": [
				"react-context"
			],
			"ui-components": [
				"lite-mode"
			],
			"deprecation": [
				"no-deprecated-imports"
			],
			"styling": [
				"static",
				"compiled"
			],
			"imports": [
				"import-no-extraneous-disable-for-examples-and-docs"
			]
		}
	},
	"name": "@atlaskit/editor-synced-block-provider",
	"version": "6.6.6",
	"description": "Synced Block Provider for @atlaskit/editor-plugin-synced-block",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"platform-feature-flags": {
		"platform_synced_block_patch_12": {
			"type": "boolean"
		}
	}
