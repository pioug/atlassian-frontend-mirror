{
	"name": "@atlaskit/layering",
	"version": "4.0.1",
	"description": "Layering provides consistent and accessible layered experience",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Design System Team",
		"singleton": true
	},
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": [
		"**/*.compiled.css"
	],
	"atlaskit:src": "src/index.tsx",
	"exports": {
		".": "./src/index.tsx",
		"./experimental/open-layer-observer": "./src/entry-points/experimental/open-layer-observer-old.tsx",
		"./layering": "./src/entry-points/layering.tsx",
		"./hooks": "./src/entry-points/hooks.tsx",
		"./experimental/open-layer-observer/open-layer-observer": "./src/entry-points/experimental/open-layer-observer.tsx",
		"./experimental/use-notify-open-layer-observer": "./src/entry-points/experimental/use-notify-open-layer-observer.tsx",
		"./experimental/use-open-layer-observer": "./src/entry-points/experimental/use-open-layer-observer.tsx",
		"./experimental/open-layer-observer-namespace-provider": "./src/entry-points/experimental/open-layer-observer-namespace-provider.tsx",
		"./experimental/types": "./src/entry-points/experimental/types.tsx"
	},
	"dependencies": {
		"@atlassian/react-compiler-gating": "workspace:^",
		"@babel/runtime": "root:*",
		"bind-event-listener": "root:*",
		"tiny-invariant": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@atlaskit/button": "workspace:^",
		"@atlaskit/modal-dialog": "workspace:^",
		"@atlassian/structured-docs-types": "workspace:^",
		"@testing-library/react": "root:*",
		"@testing-library/user-event": "root:*",
		"react": "root:*"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": "atlassian-conventions"
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"design-system": "v1",
			"ui-components": "lite-mode",
			"analytics": "analytics-next",
			"design-tokens": [
				"color",
				"spacing"
			],
			"deprecation": "no-deprecated-imports",
			"styling": [
				"static",
				"emotion"
			]
		}
	},
	"homepage": "https://atlassian.design/components"
}
