{
	"name": "@atlaskit/forge-react-types",
	"version": "2.1.0",
	"description": "Component types for Forge UI Kit React components",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-monorepo",
	"author": "Atlassian Pty Ltd",
	"types": "dist/types/index.d.ts",
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./global": "./src/components/global/__generated__/index.ts"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlaskit/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Forge UI"
	},
	"dependencies": {
		"@atlaskit/banner": "workspace:^",
		"@atlaskit/blanket": "workspace:^",
		"@atlaskit/breadcrumbs": "workspace:^",
		"@atlaskit/button": "workspace:^",
		"@atlaskit/comment": "workspace:^",
		"@atlaskit/datetime-picker": "workspace:^",
		"@atlaskit/dynamic-table": "workspace:^",
		"@atlaskit/form": "workspace:^",
		"@atlaskit/inline-edit": "workspace:^",
		"@atlaskit/modal-dialog": "workspace:^",
		"@atlaskit/navigation-system": "workspace:^",
		"@atlaskit/object": "workspace:^",
		"@atlaskit/pagination": "workspace:^",
		"@atlaskit/popup": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/progress-bar": "workspace:^",
		"@atlaskit/progress-tracker": "workspace:^",
		"@atlaskit/radio": "workspace:^",
		"@atlaskit/react-compiler-gating": "workspace:^",
		"@atlaskit/section-message": "workspace:^",
		"@atlaskit/select": "workspace:^",
		"@atlaskit/skeleton": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/tabs": "workspace:^",
		"@atlaskit/tag": "workspace:^",
		"@atlaskit/tag-group": "workspace:^",
		"@atlaskit/textarea": "workspace:^",
		"@atlaskit/textfield": "workspace:^",
		"@atlaskit/tile": "workspace:^",
		"@atlaskit/toggle": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlaskit/tooltip": "workspace:^",
		"@babel/runtime": "root:*",
		"@emotion/react": "root:*",
		"@emotion/serialize": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@atlassian/codegen": "workspace:^",
		"@atlassian/forge-ui": "workspace:^",
		"@types/node": "root:*",
		"lodash": "root:*",
		"react": "root:*",
		"ts-morph": "root:*",
		"ts-node": "root:*",
		"typescript": "root:*"
	},
	"scripts": {
		"codegen": "ts-node ./scripts/codegen-runner.ts",
		"codegen-global": "ts-node ./scripts/codegen-global-runner.ts",
		"check-types": "ts-node --type-check ./scripts/typechecker.ts"
	},
	"sideEffects": [
		"*.compiled.css"
	],
	"platform-feature-flags": {}
}
