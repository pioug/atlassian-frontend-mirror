{
	"extends": "../../../tsconfig.json",
	"include": ["./src/**/*", "./scripts/*"],
	"compilerOptions": {
		"removeComments": false
	},
	"ts-node": {
		"transpileOnly": true,
		"files": true,
		"compilerOptions": {
			"module": "Node16",
			"moduleResolution": "node16",
			"verbatimModuleSyntax": false
		}
	}
}
