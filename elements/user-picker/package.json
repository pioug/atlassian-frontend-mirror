{
	"name": "@atlaskit/user-picker",
	"version": "13.5.0",
	"description": "Fabric component for display a dropdown to select a user from",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"devDependencies": {
		"@af/integration-testing": "workspace:^",
		"@af/search-test-utils": "workspace:^",
		"@af/visual-regression": "workspace:^",
		"@atlaskit/heading": "workspace:^",
		"@atlassian/a11y-jest-testing": "workspace:^",
		"@atlassian/a11y-playwright-testing": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"@emotion/styled": "root:*",
		"@testing-library/dom": "root:*",
		"@testing-library/jest-dom": "root:*",
		"@testing-library/react": "root:*",
		"@testing-library/user-event": "root:*",
		"@types/uuid": "root:*",
		"enzyme": "root:*",
		"mock-apollo-client": "root:*",
		"react": "root:*",
		"react-beautiful-dnd": "root:*",
		"react-dom": "root:*",
		"react-intl": "root:*",
		"react-select-event": "root:*"
	},
	"sideEffects": [
		"*.compiled.css"
	],
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./analytics": "./src/analytics.ts",
		"./components/custom-option": "./src/components/CustomOption/index.ts",
		"./components/custom-option/main": "./src/components/CustomOption/main.tsx",
		"./components/email-option": "./src/components/EmailOption/index.ts",
		"./components/email-option/main": "./src/components/EmailOption/main.tsx",
		"./components/email-validation": "./src/components/emailValidation.ts",
		"./components/group-option": "./src/components/GroupOption/index.ts",
		"./components/group-option/main": "./src/components/GroupOption/main.tsx",
		"./components/option": "./src/components/Option.tsx",
		"./components/popup-user-picker": "./src/components/PopupUserPicker.tsx",
		"./components/single-value": "./src/components/SingleValue.tsx",
		"./components/team-option": "./src/components/TeamOption/index.ts",
		"./components/team-option/main": "./src/components/TeamOption/main.tsx",
		"./components/user-option": "./src/components/UserOption.tsx",
		"./components/user-picker": "./src/components/UserPicker.tsx",
		"./i18n/*": {
			"publish": null,
			"default": "./src/i18n/*.ts"
		},
		"./option": "./src/option.ts",
		"./types": "./src/types.ts",
		"./utils": "./src/components/utils.ts"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlaskit/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Search Platform: Search Experience",
		"slack": {
			"channel": "#search-plex-prs",
			"notifications": {
				"mergedPR": {
					"message": "A PR was merged in @atlaskit/user-picker without maintainer approval."
				}
			}
		},
		"website": {
			"name": "User Picker"
		}
	},
	"config": {
		"access": "public"
	},
	"dependencies": {
		"@atlaskit/afm-i18n-platform-elements-user-picker": "root:*",
		"@atlaskit/analytics-next": "workspace:^",
		"@atlaskit/avatar": "workspace:^",
		"@atlaskit/feature-gate-js-client": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/logo": "workspace:^",
		"@atlaskit/lozenge": "workspace:^",
		"@atlaskit/people-teams-ui-public": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/popper": "workspace:^",
