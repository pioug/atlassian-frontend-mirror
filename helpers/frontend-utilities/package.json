{
	"name": "@atlaskit/frontend-utilities",
	"version": "4.0.1",
	"description": "Collecton of small useful frontend utilities",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlaskit/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Frontend Platform Consortium",
		"website": {
			"name": "FrontendUtilities"
		}
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"devDependencies": {
		"@atlassian/a11y-jest-testing": "workspace:^",
		"@atlassian/structured-docs-types": "workspace:^",
		"@testing-library/react": "root:*",
		"react": "root:*",
		"typescript": "root:*",
		"wait-for-expect": "root:*"
	},
	"sideEffects": false,
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./convert-to-error": "./src/error-handling/convert-to-error/index.ts",
		"./hooks": "./src/hooks/index.ts",
		"./use-interval": "./src/hooks/use-interval/index.ts",
		"./use-previous": "./src/hooks/use-previous/index.ts",
		"./use-why-did-update": "./src/hooks/use-why-did-update/index.tsx",
		"./retry-operation": "./src/network/retry-operation/index.ts",
		"./local-storage": "./src/storage/local-storage/index.ts",
		"./storage-client": "./src/storage/storage-client/index.ts",
		"./simple-hash": "./src/utils/simple-hash/index.ts",
		"./convert-to-error/main": "./src/entry-points/convert-to-error-main.ts",
		"./hooks/use-interval": "./src/entry-points/hooks-use-interval.ts",
		"./hooks/use-local-storage": "./src/entry-points/hooks-use-local-storage.ts",
		"./hooks/use-previous": "./src/entry-points/hooks-use-previous.ts",
		"./hooks/use-why-did-update": "./src/entry-points/hooks-use-why-did-update.tsx",
		"./local-storage/main": "./src/entry-points/local-storage-main.ts",
		"./retry-operation/constants": "./src/entry-points/retry-operation-constants.ts",
		"./retry-operation/FailedFetchError": "./src/entry-points/retry-operation-FailedFetchError.ts",
		"./retry-operation/main": "./src/entry-points/retry-operation-main.ts",
		"./storage-client/main": "./src/entry-points/storage-client-main.ts"
	},
	"scripts": {
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@atlaskit/react-compiler-gating": "workspace:^",
		"@babel/runtime": "root:*",
		"lodash": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": [
				"file-and-folder-level"
			]
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"analytics": [
				"analytics-next"
			],
			"design-tokens": [
				"color"
			],
			"theming": [
				"react-context"
			],
			"ui-components": [
				"lite-mode"
			],
			"deprecation": [
				"no-deprecated-imports"
			],
			"styling": [
				"static",
				"emotion"
			]
		}
	}
}
