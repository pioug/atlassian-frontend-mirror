{
	"name": "@atlaskit/jql-ast",
	"version": "4.0.0",
	"description": "JQL Abstract Syntax Tree",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"atlassian": {
		"team": "Jira Platform: Search Experience / Empanada",
		"website": {
			"name": "JQL AST",
			"category": "JQL"
		}
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": false,
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./abstract-jast-visitor": "./src/jast-visitors/abstract-jast-visitor.ts",
		"./argument": "./src/types/ast/argument.ts",
		"./ast/clause": "./src/types/ast/clause.ts",
		"./ast/operand": "./src/types/ast/operand.ts",
		"./ast/operator": "./src/types/ast/operator.ts",
		"./ast/order-by": "./src/types/ast/order-by.ts",
		"./ast/predicate": "./src/types/ast/predicate.ts",
		"./clause": "./src/constants/clause.ts",
		"./collapsed-custom-field-types": "./src/constants/collapsed-custom-field-types.ts",
		"./common": "./src/types/ast/common.ts",
		"./compound": "./src/constants/compound.ts",
		"./compound-operator": "./src/types/ast/compound-operator.ts",
		"./creators": "./src/creators/index.ts",
		"./field": "./src/types/ast/field.ts",
		"./jast-builder": "./src/api/jast-builder.ts",
		"./jast-listener": "./src/types/api/jast-listener.ts",
		"./jast-visitor": "./src/types/api/jast-visitor.ts",
		"./jast-walker": "./src/api/jast-walker.ts",
		"./jql-anonymizer-visitor": "./src/jast-visitors/jql-anonymizer-visitor.ts",
		"./jql-insights-listener": "./src/jast-listeners/jql-insights-listener.ts",
		"./jql-parse-error": "./src/errors/jql-parse-error.ts",
		"./jql-syntax-error": "./src/errors/jql-syntax-error.ts",
		"./node": "./src/constants/node.ts",
		"./normalise-jql-string": "./src/utils/normalise-jql-string.ts",
		"./operand": "./src/constants/operand.ts",
		"./operator": "./src/constants/operator.ts",
		"./order-by": "./src/constants/order-by.ts",
		"./predicate": "./src/constants/predicate.ts",
		"./printers": "./src/printers/index.ts",
		"./privacy-safe-fields": "./src/constants/privacy-safe-fields.ts",
		"./query": "./src/types/ast/query.ts",
		"./reserved-words": "./src/constants/reserved-words.ts",
		"./sanitise-jql-string": "./src/utils/sanitise-jql-string.ts"
	},
	"dependencies": {
		"@atlaskit/jql-parser": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@babel/runtime": "root:*",
		"antlr4ts": "root:*",
		"lodash": "root:*",
		"memoize-one": "root:*"
	},
	"devDependencies": {
		"@atlaskit/docs": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"fast-csv": "root:*",
		"wait-for-expect": "root:*"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": [
				"file-and-folder-level"
			]
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"analytics": [
				"analytics-next"
			],
			"theming": [
				"react-context",
				"tokens"
			],
			"ui-components": [
				"lite-mode"
			],
			"deprecation": [
				"no-deprecated-imports"
			],
			"styling": [
				"static",
				"emotion"
			]
		}
	},
	"platform-feature-flags": {
		"queue-setting-page-jql-bug": {
			"type": "boolean"
		}
	}
}
