			]
		}
	},
	"sideEffects": [
		"*.compiled.css"
	],
	"atlaskit:src": "src/entry-points/date-label.tsx",
	"exports": {
		".": "./src/entry-points/date-label.tsx",
		"./date-label": "./src/entry-points/date-label.tsx",
		"./date-label-dropdown-trigger": "./src/entry-points/date-label-dropdown-trigger.tsx",
		"./types": "./src/entry-points/types.tsx"
	},
	"dependencies": {
		"@atlaskit/css": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/icon-lab": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
