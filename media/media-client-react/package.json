{
	"name": "@atlaskit/media-client-react",
	"version": "6.0.0",
	"description": "🖼️ Media Client for React",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Media Exif"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": false,
	"atlaskit:src": "src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./get-media-client": "./src/getMediaClient.ts",
		"./get-media-user-preferences": "./src/mediaSettings/getMediaUserPreferences.ts",
		"./media-client-provider": "./src/MediaClientProvider.tsx",
		"./media-file-state-error": "./src/MediaFileStateError.ts",
		"./media-parsed-settings": "./src/mediaSettings/mediaParsedSettings.ts",
		"./media-provider": "./src/MediaProvider.tsx",
		"./mocked-get-media-client": "./src/test-helpers/mockedGetMediaClient.ts",
		"./mocked-media-client-provider": "./src/test-helpers/MockedMediaClientProvider.tsx",
		"./mocked-media-provider": "./src/test-helpers/MockedMediaProvider.tsx",
		"./test-helpers": "./src/test-helpers/index.ts",
		"./use-copy-intent": "./src/copyIntent/useCopyIntent.ts",
		"./use-file-hashes": "./src/useFileHashes.ts",
		"./use-file-state": "./src/useFileState.ts",
		"./use-media-client": "./src/useMediaClient.ts",
		"./use-media-settings": "./src/useMediaSettings.ts",
		"./use-media-store": "./src/useMediaStore.ts",
		"./with-media-client": "./src/withMediaClient.tsx",
		"./with-media-client-and-settings": "./src/withMediaClientAndSettings.tsx"
	},
	"dependencies": {
		"@atlaskit/media-client": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/platform-feature-flags-react": "workspace:^",
		"@atlassian/react-compiler-gating": "workspace:^",
		"@babel/runtime": "root:*",
		"zustand": "root:*"
	},
	"peerDependencies": {
		"@atlaskit/analytics-next": "workspace:^",
		"@atlaskit/media-state": "workspace:^",
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"peerDependenciesMeta": {
		"@atlaskit/media-state": {
			"optional": true
		}
	},
	"devDependencies": {
		"@atlaskit/media-state": "workspace:^",
		"@atlaskit/media-test-data": "workspace:^",
		"@atlassian/feature-flags-test-utils": "workspace:^",
		"@testing-library/react": "root:*",
		"@testing-library/user-event": "root:*",
		"jest-fetch-mock": "root:*",
		"msw": "root:*",
		"react": "root:*",
		"react-dom": "root:*"
	},
	"platform-feature-flags": {
		"platform_media_cross_client_copy": {
			"type": "boolean"
		},
		"platform_media_cross_client_copy_with_auth": {
			"type": "boolean"
		},
		"media-perf-uplift-mutation-fix": {
			"type": "boolean"
		},
		"dfo_attachments_late_render_fix": {
			"type": "boolean"
		},
		"platform_media_ssr_data_seed": {
			"type": "boolean"
		}
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": [
				"atlassian-conventions"
			],
			"circular-dependencies": [
				"file-and-folder-level"
			]
		}
	}
}
