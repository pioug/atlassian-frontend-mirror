		"./blockService": "./src/entry-points/blockService.ts",
		"./blockService/ari": "./src/entry-points/blockService-ari.ts",
		"./blockSubscription": "./src/entry-points/blockSubscription.ts",
		"./clients/confluence/ari": "./src/entry-points/confluence-ari.ts",
		"./common/types": "./src/entry-points/common-types.ts",
		"./errorHandling": "./src/entry-points/errorHandling.ts",
		"./fetchJiraMediaToken": "./src/entry-points/fetchJiraMediaToken.ts",
		"./fetchMediaToken": "./src/entry-points/fetchMediaToken.ts",
		"./jira/ari": "./src/entry-points/jira-ari.ts",
		"./providers/block-service/blockServiceAPI": "./src/entry-points/blockServiceAPI.ts",
		"./providers/types": "./src/entry-points/providers-types.ts",
		"./rebaseTransaction": "./src/entry-points/rebaseTransaction.ts",
		"./referenceSyncBlockStoreManager": "./src/entry-points/referenceSyncBlockStoreManager.ts",
