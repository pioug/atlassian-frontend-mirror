{
	"name": "@atlaskit/empty-state",
	"version": "11.0.0",
	"description": "An empty state appears when there is no data to display and describes what the user can do next.",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": [
		"**/*.compiled.css"
	],
	"atlaskit:src": "src/index.tsx",
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlassian/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Design System Team",
		"website": {
			"name": "Empty state",
			"category": "Messaging"
		}
	},
	"dependencies": {
		"@atlaskit/button": "workspace:^",
		"@atlaskit/heading": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/spinner": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@atlassian/react-compiler-gating": "workspace:^",
		"@babel/runtime": "root:*",
		"@compiled/react": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0"
	},
	"devDependencies": {
		"@af/accessibility-testing": "workspace:^",
		"@af/integration-testing": "workspace:^",
		"@af/visual-regression": "workspace:^",
		"@atlaskit/docs": "workspace:^",
		"@atlaskit/link": "workspace:^",
		"@atlaskit/section-message": "workspace:^",
		"@atlassian/ssr-tests": "workspace:^",
		"@atlassian/structured-docs-types": "workspace:^",
		"@testing-library/react": "root:*",
		"react": "root:*",
		"react-dom": "root:*"
	},
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": "atlassian-conventions"
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"analytics": "analytics-next",
			"design-tokens": [
				"color",
				"spacing"
			],
			"styling": [
				"static",
				"emotion"
			],
			"design-system": "v1",
			"deprecation": "no-deprecated-imports"
		}
	},
	"homepage": "https://atlassian.design/components/empty-state/",
	"exports": {
		".": "./src/index.tsx",
		"./empty-state": "./src/entry-points/empty-state.tsx",
		"./types": "./src/entry-points/types.tsx"
	}
}
