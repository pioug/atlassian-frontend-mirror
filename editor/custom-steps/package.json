{
	"name": "@atlaskit/custom-steps",
	"version": "1.0.1",
	"description": "Editor Custom Steps",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": false,
	"atlaskit:src": "src/index.ts",
	"atlassian": {
		"team": "Editor: Collaboration",
		"singleton": true
	},
	"exports": {
		".": "./src/index.ts",
		"./add-column": "./src/entry-points/add-column.ts",
		"./constants": "./src/entry-points/constants.ts",
		"./sort-column": "./src/entry-points/sort-column.ts",
		"./types": "./src/entry-points/types.ts"
	},
	"dependencies": {
		"@atlaskit/adf-schema": "workspace:^",
		"@atlaskit/editor-prosemirror": "workspace:^",
		"@atlaskit/editor-tables": "workspace:^",
		"@babel/runtime": "root:*",
		"memoize-one": "root:*"
	},
	"techstack": {
		"@atlassian/frontend": {
			"circular-dependencies": [
				"file-level"
			]
		},
		"@repo/internal": {
			"deprecation": "no-deprecated-imports",
			"styling": [
				"emotion"
			]
		}
	}
}
