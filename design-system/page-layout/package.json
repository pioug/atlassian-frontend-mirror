{
	"name": "@atlaskit/page-layout",
	"version": "5.2.4",
	"description": "A collection of components which let you compose an application's page layout.",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"repository": "https://bitbucket.org/atlassian/atlassian-frontend-mirror",
	"author": "Atlassian Pty Ltd",
	"license": "Apache-2.0",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"module:es2019": "dist/es2019/index.js",
	"types": "dist/types/index.d.ts",
	"sideEffects": [
		"**/*.compiled.css"
	],
	"atlaskit:src": "src/index.tsx",
	"exports": {
		".": "./src/index.tsx",
		"./page-layout": "./src/entry-points/page-layout.tsx",
		"./main": "./src/entry-points/main.tsx",
		"./content": "./src/entry-points/content.tsx",
		"./right-sidebar": "./src/entry-points/right-sidebar.tsx",
		"./left-sidebar": "./src/entry-points/left-sidebar.tsx",
		"./left-sidebar-without-resize": "./src/entry-points/left-sidebar-without-resize.tsx",
		"./right-panel": "./src/entry-points/right-panel.tsx",
		"./left-panel": "./src/entry-points/left-panel.tsx",
		"./banner-slot": "./src/entry-points/banner-slot.tsx",
		"./top-navigation": "./src/entry-points/top-navigation.tsx",
		"./use-custom-skip-link": "./src/entry-points/use-custom-skip-link.tsx",
		"./constants": "./src/entry-points/constants.tsx",
		"./sidebar-resize-context": "./src/entry-points/sidebar-resize-context.tsx",
		"./types": "./src/entry-points/types.tsx"
	},
	"atlassian": {
		"react-compiler": {
			"enabled": true,
			"gating": {
				"source": "@atlaskit/react-compiler-gating",
				"importSpecifierName": "isReactCompilerActivePlatform"
			}
		},
		"team": "Design System Team",
		"website": {
			"name": "Page layout",
			"category": "Layout and structure",
			"status": {
				"type": "deprecated",
				"description": "This package is deprecated. Use our new [navigation system](/components/navigation-system)."
			}
		}
	},
	"homepage": "https://atlassian.design/components/page-layout/",
	"dependencies": {
		"@atlaskit/ds-lib": "workspace:^",
		"@atlaskit/icon": "workspace:^",
		"@atlaskit/link": "workspace:^",
		"@atlaskit/motion": "workspace:^",
		"@atlaskit/platform-feature-flags": "workspace:^",
		"@atlaskit/primitives": "workspace:^",
		"@atlaskit/react-compiler-gating": "workspace:^",
		"@atlaskit/tokens": "workspace:^",
		"@babel/runtime": "root:*",
		"@emotion/react": "root:*",
		"bind-event-listener": "root:*",
		"raf-schd": "root:*"
	},
	"peerDependencies": {
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"devDependencies": {
		"@af/accessibility-testing": "workspace:^",
		"@af/integration-testing": "workspace:^",
		"@atlaskit/atlassian-navigation": "workspace:^",
		"@atlaskit/button": "workspace:^",
		"@atlaskit/docs": "workspace:^",
		"@atlaskit/logo": "workspace:^",
		"@atlaskit/menu": "workspace:^",
		"@atlaskit/popup": "workspace:^",
		"@atlaskit/section-message": "workspace:^",
		"@atlaskit/side-navigation": "workspace:^",
		"@atlaskit/tooltip": "workspace:^",
		"@atlassian/ssr-tests": "workspace:^",
		"@testing-library/react": "root:*",
		"@types/raf-schd": "root:*",
		"raf-stub": "root:*",
		"react": "root:*",
		"react-dom": "root:*"
	},
	"platform-feature-flags": {
		"platform_dst_popup-disable-focuslock": {
			"type": "boolean",
			"referenceOnly": "true"
		},
		"platform-dst-motion-uplift-button": {
			"type": "boolean",
			"referenceOnly": true
		}
	},
	"keywords": [
		"atlaskit",
		"react",
		"ui"
	],
	"techstack": {
		"@atlassian/frontend": {
			"import-structure": "atlassian-conventions"
		},
		"@repo/internal": {
			"dom-events": "use-bind-event-listener",
			"design-system": "v1",
			"ui-components": [
				"lite-mode"
			],
			"analytics": [
				"analytics-next"
			],
			"design-tokens": [
				"color",
				"spacing"
			],
			"theming": [
				"react-context"
			],
			"deprecation": "no-deprecated-imports",
			"styling": [
				"emotion",
				"static"
			]
		}
	}
}
